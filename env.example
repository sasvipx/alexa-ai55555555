import React, { useState } from "react";
import { Copy, Check, FileJson, FileText, Lightbulb, Sparkles, Cpu, Wand2, RefreshCw } from "lucide-react";
import { SkillConfig, SkillOutput } from "../types";

interface SkillWizardProps {
  onGenerateSkill: (config: SkillConfig) => Promise<void>;
  isGeneratingSkill: boolean;
  skillOutput: SkillOutput | null;
}

export default function SkillWizard({
  onGenerateSkill,
  isGeneratingSkill,
  skillOutput,
}: SkillWizardProps) {
  const [copiedSection, setCopiedSection] = useState<string | null>(null);
  const [activeTab, setActiveTab] = useState<"interaction" | "lambda" | "guide">("guide");
  
  const [config, setConfig] = useState<SkillConfig>({
    skillName: "الذكي العربي الفائق",
    invocationName: "الذكي العربي",
    skillType: "ai_general",
    aiIntelligence: "super-intelligent",
    customIntents: "التحكم بالأجهزة المنزلية، قصص الأطفال التفاعلية، تنظيم مواعيد اليوم، تفسير آيات القرآن الكريم",
  });

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>) => {
    const { name, value } = e.target;
    setConfig((prev) => ({ ...prev, [name]: value }));
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    onGenerateSkill(config);
    // Switch to guide tab by default to read how to deploy
    setActiveTab("guide");
  };

  const copyToClipboard = (text: string, section: "interaction" | "lambda") => {
    navigator.clipboard.writeText(text);
    setCopiedSection(section);
    setTimeout(() => setCopiedSection(null), 2000);
  };

  return (
    <div className="bg-slate-900 border border-slate-800 rounded-3xl p-6 shadow-2xl text-right" id="skill_generator_section">
      <div className="flex items-center gap-2 justify-end mb-4 border-b border-slate-800 pb-3">
        <div>
          <h2 className="text-lg md:text-xl font-bold text-slate-100 flex items-center gap-2 justify-end">
            <span className="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 to-emerald-400">منشئ مهارات أليكسا الذكي</span>
            <Cpu className="w-6 h-6 text-emerald-400" />
          </h2>
          <p className="text-slate-400 text-xs mt-0.5">اصنع وصمم مهارة متكاملة لجهاز Echo Dot 5 الخاص بك باللغة العربية بالكامل</p>
        </div>
      </div>

      <form onSubmit={handleSubmit} className="space-y-4">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          {/* Skill Full Name */}
          <div>
            <label className="block text-xs font-semibold text-slate-400 mb-1.5">اسم المهارة بالكامل (مثال: الذكي العربي)</label>
            <input
              type="text"
              name="skillName"
              value={config.skillName}
              onChange={handleInputChange}
              required
              className="w-full px-4 py-2.5 bg-slate-950 border border-slate-805/60 focus:border-emerald-500 focus:outline-none rounded-xl text-xs text-slate-100 placeholder-slate-600 text-right"
              placeholder="مثال: الذكي العربي المساعد"
            />
          </div>

          {/* Alexa Invocation Name */}
          <div>
            <label className="block text-xs font-semibold text-slate-400 mb-1.5 flex items-center gap-1 justify-end">
              <span>اسم الاستدعاء الصوتي (ثلاث عبارات عربية كحد أقصى)</span>
              <Lightbulb className="w-3.5 h-3.5 text-amber-500" />
            </label>
            <input
              type="text"
              name="invocationName"
              value={config.invocationName}
              onChange={handleInputChange}
              required
              className="w-full px-4 py-2.5 bg-slate-950 border border-slate-805/60 focus:border-emerald-500 focus:outline-none rounded-xl text-xs text-slate-100 placeholder-slate-600 text-right"
              placeholder="الكلمة التي تنادي بها أليكسا (مثال: الذكي العربي)"
            />
            <p className="text-[10px] text-slate-500 mt-1">الاسم الصوتي لتشغيل المهارة، كأن تقول "أليكسا، افتحي الذكي العربي"</p>
          </div>

        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          {/* Skill Type Selection */}
          <div>
            <label className="block text-xs font-semibold text-slate-400 mb-1.5">غرض المهارة وتصنيفها الرئيسي</label>
            <select
              name="skillType"
              value={config.skillType}
              onChange={handleInputChange}
              className="w-full px-4 py-2.5 bg-slate-950 border border-slate-850 focus:border-emerald-500 focus:outline-none rounded-xl text-xs text-slate-300 text-right"
            >
              <option value="ai_general">ذكاء اصطناعي وأسئلة عامة (حوار منبسط عالي الذكاء)</option>
              <option value="storyteller">قصص الأطفال والتعليم التفاعلي (رواية القصص الملهمة)</option>
              <option value="smart_home">المنزل الذكي (التحكم باللمبات والأجهزة الذكية بالصوت)</option>
              <option value="zen_reminders">أذكار دينية وعبادات ومواعيد الصلاة</option>
              <option value="productivity">زيادة الإنتاجية وتنظيم جدول الأعمال اليومي</option>
            </select>
          </div>

          {/* AI Intelligence Tier */}
          <div>
            <label className="block text-xs font-semibold text-slate-400 mb-1.5">مستوى الذكاء والمحرك البرمجي</label>
            <select
              name="aiIntelligence"
              value={config.aiIntelligence}
              onChange={handleInputChange}
              className="w-full px-4 py-2.5 bg-slate-950 border border-slate-850 focus:border-emerald-500 focus:outline-none rounded-xl text-xs text-slate-300 text-right"
            >
              <option value="super-intelligent">ذكاء اصطناعي فائق (تكامل فوري ومباشر مع الـ Gemini API)</option>
              <option value="standard">استجابات قياسية تفاعلية (كود محلي منظم وسريع دون نفقات خارجية)</option>
            </select>
          </div>

        </div>

        {/* Custom Intent specifications */}
        <div>
          <label className="block text-xs font-semibold text-slate-400 mb-1.5">أمثلة على التفاعلات أو الميزات المخصصة التي ترغب بإضافتها</label>
          <textarea
            name="customIntents"
            value={config.customIntents}
            onChange={handleInputChange}
            rows={2}
            className="w-full px-4 py-2.5 bg-slate-950 border border-slate-850 focus:border-emerald-500 focus:outline-none rounded-xl text-xs text-slate-100 placeholder-slate-600 text-right resize-none"
            placeholder="اكتب تفاصيل إضافية تريد توليد الأكواد لخدمتها..."
          />
        </div>

        {/* Action Button */}
        <div className="flex justify-start">
          <button
            type="submit"
            disabled={isGeneratingSkill}
            className="px-6 py-3 bg-gradient-to-l from-emerald-600 to-blue-600 hover:from-emerald-500 hover:to-blue-500 active:scale-[0.98] disabled:from-slate-800 disabled:to-slate-900 text-white font-bold text-xs rounded-xl flex items-center gap-2 shadow-lg transition-all focus:outline-none cursor-pointer"
          >
            {isGeneratingSkill ? (
              <>
                <RefreshCw className="w-4 h-4 animate-spin text-emerald-200" />
                <span>جاري معالجة الكود العربي الذكي...</span>
              </>
            ) : (
              <>
                <Wand2 className="w-4 h-4 text-emerald-200" />
                <span>توليد كود المهارة والمستندات بذكاء Gemini</span>
              </>
            )}
          </button>
        </div>
      </form>

      {/* RENDER CODE GENERATOR RESULTS */}
      {skillOutput && (
        <div className="mt-8 border-t border-slate-800 pt-6 animate-fade-in">
          
          <div className="flex flex-col sm:flex-row justify-between items-stretch gap-4 mb-4 pb-2 border-b border-slate-850">
            <h3 className="text-sm font-bold text-slate-200 flex items-center justify-end gap-1.5 self-center">
              <span>توليد مخرجات المهارة بنجاح</span>
              <Sparkles className="w-4 h-4 text-amber-400" />
            </h3>
            
            {/* Tabs Selector */}
            <div className="flex rounded-lg bg-slate-950 p-1 border border-slate-850 text-xs self-start">
              <button
                type="button"
                onClick={() => setActiveTab("guide")}
                className={`px-3 py-1.5 rounded-md font-semibold transition-all ${
                  activeTab === "guide" 
                    ? "bg-slate-850 text-slate-100 shadow-sm" 
                    : "text-slate-400 hover:text-slate-200"
                }`}
              >
                دليل التركيب والتشغيل 📖
              </button>
              <button
                type="button"
                onClick={() => setActiveTab("lambda")}
                className={`px-3 py-1.5 rounded-md font-semibold transition-all flex items-center gap-2 ${
                  activeTab === "lambda" 
                    ? "bg-slate-850 text-slate-100 shadow-sm animate-pulse" 
                    : "text-slate-400 hover:text-slate-200"
                }`}
              >
                كود الخلفية (index.js) ⚡
              </button>
              <button
                type="button"
                onClick={() => setActiveTab("interaction")}
                className={`px-3 py-1.5 rounded-md font-semibold transition-all ${
                  activeTab === "interaction" 
                    ? "bg-slate-850 text-slate-100 shadow-sm" 
                    : "text-slate-400 hover:text-slate-200"
                }`}
              >
                نموذج التفاعل (JSON) 🤖
              </button>
            </div>
          </div>

          {/* TAB CONTENTS */}
          <div className="transition-all duration-300">
            
            {/* 1. INTERACTION MODEL TAB */}
            {activeTab === "interaction" && (
              <div className="space-y-2">
                <div className="flex justify-between items-center bg-slate-950 p-3 rounded-t-xl border-b border-slate-900">
                  <button
                    type="button"
                    onClick={() => copyToClipboard(skillOutput.interactionModel, "interaction")}
                    className="flex items-center gap-1.5 px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 hover:text-white rounded-lg text-xs transition-colors cursor-pointer"
                  >
                    {copiedSection === "interaction" ? (
                      <>
                        <Check className="w-3.5 h-3.5 text-emerald-400" />
                        <span className="text-emerald-400">تم النسخ!</span>
                      </>
                    ) : (
                      <>
                        <Copy className="w-3.5 h-3.5" />
                        <span>نسخ الكود</span>
                      </>
                    )}
                  </button>
                  <span className="flex items-center gap-1.5 font-mono text-[11px] text-slate-400 bg-slate-900 px-2 py-0.5 rounded border border-slate-800">
                    <span>InteractionModel.json</span>
                    <FileJson className="w-3.5 h-3.5 text-blue-400" />
                  </span>
                </div>
                <div className="bg-slate-950 p-4 rounded-b-xl border border-t-0 border-slate-850 max-h-[450px] overflow-auto">
                  <pre className="text-left font-mono text-xs text-sky-300 leading-relaxed overflow-x-auto whitespace-pre">
                    {skillOutput.interactionModel}
                  </pre>
                </div>
                <p className="text-[10px] text-slate-500 text-right pt-1">
                  💡 انسخ هذا الـ JSON وضعه مباشرة في خيار "JSON Editor" في صفحة تفاعلات كونسول أمازون أليكسا.
                </p>
              </div>
            )}

            {/* 2. LAMBDA CODE TAB */}
            {activeTab === "lambda" && (
              <div className="space-y-2">
                <div className="flex justify-between items-center bg-slate-950 p-3 rounded-t-xl border-b border-slate-900">
                  <button
                    type="button"
                    onClick={() => copyToClipboard(skillOutput.lambdaCode, "lambda")}
                    className="flex items-center gap-1.5 px-3 py-1 bg-slate-900 border border-slate-800 text-slate-300 hover:text-white rounded-lg text-xs transition-colors cursor-pointer"
                  >
                    {copiedSection === "lambda" ? (
                      <>
                        <Check className="w-3.5 h-3.5 text-emerald-400" />
                        <span className="text-emerald-400">تم النسخ!</span>
                      </>
                    ) : (
                      <>
                        <Copy className="w-3.5 h-3.5" />
                        <span>نسخ الكود</span>
                      </>
                    )}
                  </button>
                  <span className="flex items-center gap-1.5 font-mono text-[11px] text-slate-400 bg-slate-900 px-2 py-0.5 rounded border border-slate-800">
                    <span>index.js (Alexa Custom Handler)</span>
                    <FileText className="w-3.5 h-3.5 text-emerald-400" />
                  </span>
                </div>
                <div className="bg-slate-950 p-4 rounded-b-xl border border-t-0 border-slate-850 max-h-[450px] overflow-auto">
                  <pre className="text-left font-mono text-xs text-emerald-300/90 leading-relaxed overflow-x-auto whitespace-pre">
                    {skillOutput.lambdaCode}
                  </pre>
                </div>
                <p className="text-[10px] text-slate-500 text-right pt-1">
                  💡 هذا هو الكود الذكي المكتوب لحزمة ASK SDK. يتضمن محرك إرسال مخصص إلى Gemini API للحصول على إجابات للمسائل الصعبة إن تم تحديده.
                </p>
              </div>
            )}

            {/* 3. GUIDE TAB */}
            {activeTab === "guide" && (
              <div className="bg-slate-950/85 p-6 rounded-2xl border border-slate-850 max-h-[500px] overflow-y-auto leading-relaxed text-slate-200">
                <div className="prose prose-invert max-w-none text-right">
                  <h4 className="text-emerald-400 font-bold text-sm mb-3">دليل نشر وتشغيل المهارة على جهاز Amazon Echo Dot 5 الخاص بك:</h4>
                  <div className="whitespace-pre-line text-xs font-sans space-y-4 text-slate-300">
                    {skillOutput.skillGuide}
                  </div>
                </div>
              </div>
            )}

          </div>

        </div>
      )}

    </div>
  );
}
